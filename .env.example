# ── Core ─────────────────────────────────────────────
NODE_ENV=development
API_PORT=4000
APP_URL=http://localhost:3001
API_URL=http://localhost:4000

# ── MongoDB (primary datastore) ──────────────────────
MONGO_URI=mongodb://localhost:27017/crossbill

# ── Redis ────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── Auth ─────────────────────────────────────────────
JWT_ACCESS_SECRET=change-me-access
JWT_REFRESH_SECRET=change-me-refresh
ACCESS_TOKEN_TTL=900            # seconds (15 min)
REFRESH_TOKEN_TTL=2592000       # seconds (30 days)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:4000/api/v1/auth/google/callback

# ── Billing (Razorpay) ───────────────────────────────
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=

# ── Email (Resend) ───────────────────────────────────
RESEND_API_KEY=
EMAIL_FROM=Crossbill <no-reply@crossbill.app>

# ── Python PDF service ───────────────────────────────
PDF_SERVICE_URL=http://localhost:8000
INTERNAL_SERVICE_TOKEN=change-me-internal-token

# ── Storage (object store / S3-compatible) ───────────
STORAGE_BUCKET=crossbill-docs
STORAGE_ACCESS_KEY=
STORAGE_SECRET_KEY=
STORAGE_ENDPOINT=
